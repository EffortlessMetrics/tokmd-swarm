{
  "schema": "tokmd.bindings_parity_manifest.v1",
  "agent_charter": ".github/agents/bindings-parity-keeper.agent.md",
  "cases": [
    {
      "id": "version",
      "mode": "version",
      "args": "{}",
      "expect_ok": true,
      "data_has_keys": ["version", "schema_version"],
      "data_contains": {
        "schema_version": 2
      }
    },
    {
      "id": "unknown_mode",
      "mode": "bogus_mode",
      "args": "{}",
      "expect_ok": false,
      "golden": "golden/unknown_mode.json",
      "error_contains": {
        "code": "unknown_mode"
      }
    },
    {
      "id": "invalid_json",
      "mode": "lang",
      "args": "not valid json",
      "expect_ok": false,
      "golden": "golden/invalid_json.json",
      "error_contains": {
        "code": "invalid_json"
      }
    },
    {
      "id": "invalid_settings",
      "mode": "lang",
      "args": "{\"children\": \"invalid\"}",
      "expect_ok": false,
      "error_contains": {
        "code": "invalid_settings"
      }
    },
    {
      "id": "lang_in_memory",
      "mode": "lang",
      "args": "{\"inputs\":[{\"path\":\"sample.rs\",\"text\":\"fn main() {}\"}]}",
      "expect_ok": true,
      "data_contains": {
        "mode": "lang",
        "schema_version": 2
      },
      "data_has_keys": ["rows", "total"]
    },
    {
      "id": "module_in_memory",
      "mode": "module",
      "args": "{\"inputs\":[{\"path\":\"src/lib.rs\",\"text\":\"fn main() {}\"}]}",
      "expect_ok": true,
      "data_contains": {
        "mode": "module",
        "schema_version": 2
      },
      "data_has_keys": ["rows"]
    },
    {
      "id": "export_in_memory",
      "mode": "export",
      "args": "{\"inputs\":[{\"path\":\"lib.rs\",\"text\":\"fn main() {}\"}],\"format\":\"json\"}",
      "expect_ok": true,
      "data_contains": {
        "mode": "export",
        "schema_version": 2
      },
      "data_has_keys": ["rows"]
    }
  ]
}
